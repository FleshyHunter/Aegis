# Copy this file to .env and fill in local values.

# MongoDB
MONGO_URI=mongodb://localhost:27017/AEGIS

# Python binary used by the backend when spawning the Python pipeline.
# Docker uses /usr/bin/python3. Local macOS/dev setups usually use python3.
PYTHON_BIN=python3

# Pipeline mode
# Set true to use the local MockDifyClient instead of real Dify API calls.
USE_MOCK_LLM=false

# Dify
DIFY_BASE_URL=https://api.dify.ai/v1
DIFY_ROUTING_API_KEY=
DIFY_EVALUATION_API_KEY=
DIFY_TIMEOUT_SECONDS=60
DIFY_RESPONSE_MODE=blocking
DIFY_USER=aegis

# Optional metadata only. The actual model is configured inside Dify Studio.
LLM_MODEL=

# Pipeline throttling
MAX_EVALUATION_CANDIDATES=2
MAX_PARALLEL_TICKETS=5
MAX_DIFY_RPM=60

# Jira / Atlassian
# Keep blank unless Jira integration is being used.
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
